   "source": [
    "# Write a python program to find whether a given numbeer is even or odd, print out an approciate message to the user.\n",
    "\n",
    "a = int(input(\"Enter the number: \"))\n",
    "\n",
    "if a % 2 == 0:\n",
    "    print(f\"{a} is an Even Number\")\n",
    "else:\n",
    "    print(f\"{a} is an Odd Number\")"
   ]
  }
