   "source": [
    "# Write a Python Program to get the Factorial number of given numbers.\n",
    "\n",
    "num = 8\n",
    "fact = 1\n",
    "for i in range(1, num+1):\n",
    "    fact *= num\n",
    "    num -= 1\n",
    "print(\"Factorial Number is: \", fact)"
   ]
