   "source": [
    "#  Write a Python function to reverses a string if its length is a multiple \n",
    "# of 4.\n",
    "\n",
    "def reverse_string(string):\n",
    "    if len(string) % 4 == 0:\n",
    "        return string[::-1]\n",
    "    else:\n",
    "        return string\n",
    "\n",
    "text = input(\"Enter a string: \")\n",
    "\n",
    "print(\"Result: \", reverse_string(text))"
   ]
  }
